{
  "extends": [
    "development"
  ],
  "hints": {
    "no-inline-styles": "off",
    "axe/name-role-value": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "-webkit-text-size-adjust",
          "background-color: color-mix(in srgb,oklch(.379 .146 265.522) 20%,transparent)",
          "background-color: color-mix(in srgb,oklch(.278 .033 256.848) 50%,transparent)",
          "background-color: color-mix(in srgb,oklch(.278 .033 256.848) 80%,transparent)",
          "background-color: color-mix(in srgb,oklch(.278 .033 256.848) 95%,transparent)"
        ]
      }
    ]
  }
}